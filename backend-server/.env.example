# ============================================================
# AI 민원 시스템 — 백엔드 환경변수 설정 파일
# ============================================================
# ❗ 사용법:
#    1. 이 파일을 복사해서 .env 로 이름 변경
#       (Windows)  copy .env.example .env
#       (Mac/Linux) cp .env.example .env
#    2. 아래 빈칸을 실제 값으로 채우기
#    3. .env 파일은 절대 git에 올리지 말 것!
# ============================================================

# ── OpenAI API Key ───────────────────────────────────────────
# 발급: https://platform.openai.com/api-keys
# Whisper(STT) + GPT-4o mini(NLP) 에 사용됩니다
OPENAI_API_KEY=sk-proj-여기에_OpenAI_API_키_입력

# ── KakaoMap API Key ─────────────────────────────────────────
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 관리자 대시보드 지도 표시에 사용됩니다
KAKAO_MAP_API_KEY=여기에_카카오맵_API_키_입력

# ── Supabase ─────────────────────────────────────────────────
# 확인: https://supabase.com → 프로젝트 → Settings → API
SUPABASE_URL=https://여기에_프로젝트ID.supabase.co
SUPABASE_KEY=여기에_anon_public_키_입력
