// ============================================================

// ── 서버 주소 설정 ────────────────────────────────────────────
// ✅ AWS 배포 후:   'http://EC2_퍼블릭IP:8000'
// ✅ ngrok 사용 시: 'https://xxxx-xxx-xxx.ngrok-free.app'
// ✅ 에뮬레이터:    'http://10.0.2.2:8000'
// ✅ 실기기(로컬):  'http://PC의_IP주소:8000'

const String kServerUrl = 'http://여기에_서버_주소_입력:8000';
